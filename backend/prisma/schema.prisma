// ============================================================
// KATIYA STATION RMS — PRISMA SCHEMA
// Self-hosted PostgreSQL schema, translated from supabase_schema.sql
// Status/role/type fields kept as validated strings (not Postgres
// enums) to mirror the original CHECK constraints 1:1 and keep
// JSON payloads stable for the existing Flutter client.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ──────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String // super_admin | branch_manager | cashier | waiter | kitchen | inventory | accountant
  branchId     String?  @map("branch_id")
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  refreshTokens        RefreshToken[]
  deviceTokens          DeviceToken[]
  passwordResetTokens   PasswordResetToken[]
  waiterSessions        TableSession[]        @relation("SessionWaiter")
  waiterKots            Kot[]                 @relation("KotWaiter")
  cashierBills          Bill[]                @relation("BillCashier")
  createdLoyaltyTxns    LoyaltyTransaction[]  @relation("LoyaltyCreatedBy")
  auditLogs             AuditLog[]
  cashierShiftClosings  ShiftClosing[]        @relation("ShiftCashier")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String? // android | ios | windows | web
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ── 1. Branches ──────────────────────────────────────────────

model Branch {
  id                 String   @id @default(uuid())
  name               String
  city               String?
  address            String?
  phone              String?
  email              String?
  taxRegNumber       String?  @map("tax_reg_number")
  vatRate            Decimal  @default(13.0) @map("vat_rate")
  serviceChargeRate  Decimal  @default(10.0) @map("service_charge_rate")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  users             User[]
  tables            RestaurantTable[]
  sessions          TableSession[]
  kots              Kot[]
  menuCategories    MenuCategory[]
  menuItems         MenuItem[]
  bills             Bill[]
  creditRecords     CreditRecord[]
  inventoryItems    InventoryItem[]
  barStock          BarStock[]
  barTransactions   BarTransaction[]
  suppliers         Supplier[]
  purchases         Purchase[]
  expenses          Expense[]
  customers         Customer[]
  reservations      Reservation[]
  loyaltyTxns       LoyaltyTransaction[]
  staffMembers      StaffMember[]
  auditLogs         AuditLog[]
  shiftClosings     ShiftClosing[]
  recipes           Recipe[]
  stockMovements    StockMovement[]
  notifications     Notification[]

  @@map("branches")
}

// ── 3. Restaurant Tables ────────────────────────────────────

model RestaurantTable {
  id                String    @id @default(uuid())
  branchId          String    @map("branch_id")
  tableNumber       String    @map("table_number")
  section           String    @default("Main")
  capacity          Int       @default(4)
  status            String    @default("available") // available | occupied | reserved | cleaning | ready_for_billing | closed
  currentSessionId  String?   @unique @map("current_session_id")
  billRequested     Boolean   @default(false) @map("bill_requested")
  billRequestedAt   DateTime? @map("bill_requested_at")
  isEnabled         Boolean   @default(true) @map("is_enabled")
  description       String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  currentSession TableSession?  @relation("CurrentSession", fields: [currentSessionId], references: [id], onDelete: SetNull)
  sessions       TableSession[] @relation("TableSessions")
  kots           Kot[]
  reservations   Reservation[]
  bills          Bill[]

  @@unique([branchId, tableNumber])
  @@map("restaurant_tables")
}

// ── 4. Table Sessions ───────────────────────────────────────

model TableSession {
  id              String    @id @default(uuid())
  tableId         String    @map("table_id")
  branchId        String    @map("branch_id")
  sessionNumber   String    @map("session_number")
  status          String    @default("open") // open | closed | billed
  waiterId        String?   @map("waiter_id")
  customerId      String?   @map("customer_id")
  guestCount      Int       @default(1) @map("guest_count")
  totalAmount     Decimal   @default(0.0) @map("total_amount")
  openedAt        DateTime  @default(now()) @map("opened_at")
  closedAt        DateTime? @map("closed_at")
  billRequested   Boolean   @default(false) @map("bill_requested")
  billRequestedAt DateTime? @map("bill_requested_at")
  onHold          Boolean   @default(false) @map("on_hold")
  holdReason      String?   @map("hold_reason")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  table          RestaurantTable  @relation("TableSessions", fields: [tableId], references: [id], onDelete: Cascade)
  currentForTable RestaurantTable? @relation("CurrentSession")
  branch         Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  waiter         User?            @relation("SessionWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  kots           Kot[]
  bills          Bill[]

  @@map("table_sessions")
}

// ── 5. KOTs ──────────────────────────────────────────────────

model Kot {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  branchId    String   @map("branch_id")
  tableId     String?  @map("table_id")
  kotNumber   String   @map("kot_number")
  status      String   @default("pending") // pending | preparing | ready | served | cancelled
  waiterId    String?  @map("waiter_id")
  itemsCount  Int      @default(0) @map("items_count")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session TableSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  branch  Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table   RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  waiter  User?            @relation("KotWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  items   KotItem[]

  @@map("kots")
}

// ── 8. KOT Items ─────────────────────────────────────────────

model KotItem {
  id         String   @id @default(uuid())
  kotId      String   @map("kot_id")
  menuItemId String   @map("menu_item_id")
  name       String
  quantity   Int
  unitPrice  Decimal  @default(0.0) @map("unit_price")
  status     String   @default("pending") // pending | preparing | ready | served | cancelled
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  kot      Kot      @relation(fields: [kotId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@map("kot_items")
}

// ── 6. Menu Categories ──────────────────────────────────────

model MenuCategory {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  name      String
  type      String   @default("food") // food | drink | bar
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  branch Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items  MenuItem[]

  @@unique([branchId, name])
  @@map("menu_categories")
}

// ── 7. Menu Items ────────────────────────────────────────────

model MenuItem {
  id          String   @id @default(uuid())
  branchId    String   @map("branch_id")
  categoryId  String   @map("category_id")
  name        String
  price       Decimal
  costPrice   Decimal? @map("cost_price")
  taxRate     Decimal  @default(0.13) @map("tax_rate")
  description String?
  imageUrl    String?  @map("image_url")
  isAvailable Boolean  @default(true) @map("is_available")
  type        String   @default("food") // food | drink | bar
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category MenuCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  kotItems KotItem[]
  recipe   Recipe?

  @@map("menu_items")
}

// ── 9. Bills ─────────────────────────────────────────────────

model Bill {
  id             String   @id @default(uuid())
  branchId       String   @map("branch_id")
  sessionId      String?  @map("session_id")
  tableId        String?  @map("table_id")
  billNumber     String   @map("bill_number")
  invoiceNumber  String?  @map("invoice_number")
  subTotal       Decimal  @map("sub_total")
  discount       Decimal  @default(0.0)
  serviceCharge  Decimal  @default(0.0) @map("service_charge")
  vatAmount      Decimal  @default(0.0) @map("vat_amount")
  totalAmount    Decimal  @map("total_amount")
  amountPaid     Decimal  @default(0.0) @map("amount_paid")
  changeAmount   Decimal  @default(0.0) @map("change_amount")
  paymentMethod  String   @default("cash") @map("payment_method")
  paymentStatus  String   @default("paid") @map("payment_status")
  cashierId      String?  @map("cashier_id")
  cashierName    String?  @map("cashier_name")
  customerName   String?  @map("customer_name")
  customerPhone  String?  @map("customer_phone")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  branch  Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  session TableSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  table   RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  cashier User?           @relation("BillCashier", fields: [cashierId], references: [id], onDelete: SetNull)
  creditRecords CreditRecord[]

  @@map("bills")
}

// ── 10. Credit Records (Udhaaro) ────────────────────────────

model CreditRecord {
  id            String    @id @default(uuid())
  branchId      String    @map("branch_id")
  billId        String    @map("bill_id")
  customerId    String    @map("customer_id")
  customerName  String?   @map("customer_name")
  customerPhone String?   @map("customer_phone")
  creditAmount  Decimal   @map("credit_amount")
  paidAmount    Decimal   @default(0.0) @map("paid_amount")
  status        String    @default("pending") // pending | partial_paid | paid | overdue
  dueDate       DateTime? @map("due_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("credit_records")
}

// ── 11. Inventory Items ─────────────────────────────────────

model InventoryItem {
  id            String   @id @default(uuid())
  branchId      String   @map("branch_id")
  name          String
  unit          String
  currentStock  Decimal  @default(0.0) @map("current_stock")
  reorderLevel  Decimal  @default(0.0) @map("reorder_level")
  costPerUnit   Decimal? @map("cost_per_unit")
  supplierId    String?  @map("supplier_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branch          Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier        Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseItems   PurchaseItem[]
  recipeIngredients RecipeIngredient[]
  stockMovements  StockMovement[]

  @@map("inventory_items")
}

// ── 12. Bar Stock ────────────────────────────────────────────

model BarStock {
  id                 String   @id @default(uuid())
  branchId           String   @map("branch_id")
  name               String
  category           String   @default("spirits")
  bottleCapacityMl   Decimal  @default(750) @map("bottle_capacity_ml")
  currentBottles     Decimal  @default(0.0) @map("current_bottles")
  pegsMl             Decimal  @default(30) @map("pegs_ml")
  pricePerPeg        Decimal  @default(0.0) @map("price_per_peg")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  branch       Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  transactions BarTransaction[]

  @@map("bar_stock")
}

// ── 13. Bar Transactions ─────────────────────────────────────

model BarTransaction {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  itemId    String   @map("item_id")
  type      String // in | out | spill | audit
  quantity  Decimal
  createdAt DateTime @default(now()) @map("created_at")

  branch Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  item   BarStock @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("bar_transactions")
}

// ── 14. Suppliers ────────────────────────────────────────────

model Supplier {
  id            String   @id @default(uuid())
  branchId      String   @map("branch_id")
  name          String
  contactPerson String?  @map("contact_person")
  phone         String?
  email         String?
  category      String?
  address       String?
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  inventoryItems  InventoryItem[]
  purchases       Purchase[]

  @@map("suppliers")
}

// ── 15. Purchases ────────────────────────────────────────────

model Purchase {
  id           String   @id @default(uuid())
  branchId     String   @map("branch_id")
  supplierId   String?  @map("supplier_id")
  supplierName String?  @map("supplier_name")
  notes        String?
  totalAmount  Decimal  @default(0.0) @map("total_amount")
  status       String   @default("completed") // pending | completed | cancelled
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  branch   Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseItem[]

  @@map("purchases")
}

// ── 16. Purchase Items ───────────────────────────────────────

model PurchaseItem {
  id                String  @id @default(uuid())
  purchaseId        String  @map("purchase_id")
  inventoryItemId   String  @map("inventory_item_id")
  quantity          Decimal
  unitCost          Decimal @map("unit_cost")

  purchase      Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@map("purchase_items")
}

// ── 17. Expenses ─────────────────────────────────────────────

model Expense {
  id          String   @id @default(uuid())
  branchId    String   @map("branch_id")
  title       String?
  category    String
  amount      Decimal
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ── 18. Customers ────────────────────────────────────────────

model Customer {
  id             String   @id @default(uuid())
  branchId       String   @map("branch_id")
  name           String
  phone          String   @unique
  email          String?
  address        String?
  loyaltyPoints  Int      @default(0) @map("loyalty_points")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  branch      Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  loyaltyTxns LoyaltyTransaction[]

  @@map("customers")
}

// ── 19. Reservations ─────────────────────────────────────────

model Reservation {
  id               String   @id @default(uuid())
  branchId         String   @map("branch_id")
  customerName     String   @map("customer_name")
  customerPhone    String   @map("customer_phone")
  guestCount       Int      @default(2) @map("guest_count")
  reservationTime  DateTime @map("reservation_time")
  status           String   @default("pending") // pending | confirmed | arrived | completed | cancelled | no_show
  tableId          String?  @map("table_id")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  branch Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  table  RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@map("reservations")
}

// ── 20. Loyalty Transactions ─────────────────────────────────

model LoyaltyTransaction {
  id              String   @id @default(uuid())
  customerId      String   @map("customer_id")
  branchId        String   @map("branch_id")
  type            String // earn | redeem
  points          Int
  purchaseAmount  Decimal  @default(0.0) @map("purchase_amount")
  notes           String?
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  creator  User?    @relation("LoyaltyCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("loyalty_transactions")
}

// ── 21. Staff Members ────────────────────────────────────────

model StaffMember {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  userId    String?  @unique @map("user_id") // links to a login account for self-service attendance
  name      String
  role      String
  phone     String?
  salary    Decimal  @default(0.0)
  status    String   @default("active") // active | inactive | terminated
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch      Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  attendance  Attendance[]
  salaries    Salary[]

  @@map("staff_members")
}

// ── 22. Attendance ───────────────────────────────────────────

model Attendance {
  id        String    @id @default(uuid())
  staffId   String    @map("staff_id")
  date      DateTime  @default(now()) @db.Date
  clockIn   DateTime  @default(now()) @map("clock_in")
  clockOut  DateTime? @map("clock_out")
  status    String    @default("present") // present | absent | late | half_day

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("attendance")
}

// ── 23. Salaries ─────────────────────────────────────────────

model Salary {
  id       String   @id @default(uuid())
  staffId  String   @map("staff_id")
  amount   Decimal
  paidAt   DateTime @default(now()) @map("paid_at")
  status   String   @default("paid") // paid | pending

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("salaries")
}

// ── 24. Audit Logs ───────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  branchId   String?  @map("branch_id")
  userId     String?  @map("user_id")
  action     String
  tableName  String   @map("table_name")
  rowId      String?  @map("row_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ── 25. Shift Closings ───────────────────────────────────────

model ShiftClosing {
  id                   String   @id @default(uuid())
  branchId             String   @map("branch_id")
  cashierId            String?  @map("cashier_id")
  cashierName          String?  @map("cashier_name")
  date                 String
  cashTotal            Decimal  @default(0.0) @map("cash_total")
  cardTotal            Decimal  @default(0.0) @map("card_total")
  esewaTotal           Decimal  @default(0.0) @map("esewa_total")
  khaltiTotal          Decimal  @default(0.0) @map("khalti_total")
  fonepayTotal         Decimal  @default(0.0) @map("fonepay_total")
  creditTotal          Decimal  @default(0.0) @map("credit_total")
  refundTotal          Decimal  @default(0.0) @map("refund_total")
  totalRevenue         Decimal  @default(0.0) @map("total_revenue")
  netRevenue           Decimal  @default(0.0) @map("net_revenue")
  totalVat             Decimal  @default(0.0) @map("total_vat")
  totalDiscount        Decimal  @default(0.0) @map("total_discount")
  totalServiceCharge   Decimal  @default(0.0) @map("total_service_charge")
  billCount            Int      @default(0) @map("bill_count")
  status               String   @default("pending_approval") // pending_approval | approved | rejected
  createdAt            DateTime @default(now()) @map("created_at")

  branch  Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashier User?  @relation("ShiftCashier", fields: [cashierId], references: [id], onDelete: SetNull)

  @@map("shift_closings")
}

// ── 26. Recipes ──────────────────────────────────────────────

model Recipe {
  id            String   @id @default(uuid())
  menuItemId    String   @unique @map("menu_item_id")
  branchId      String   @map("branch_id")
  instructions  String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@map("recipes")
}

// ── 27. Recipe Ingredients ───────────────────────────────────

model RecipeIngredient {
  id                String   @id @default(uuid())
  recipeId          String   @map("recipe_id")
  inventoryItemId   String   @map("inventory_item_id")
  quantity          Decimal
  createdAt         DateTime @default(now()) @map("created_at")

  recipe        Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([recipeId, inventoryItemId])
  @@map("recipe_ingredients")
}

// ── 28. Stock Movements ──────────────────────────────────────

model StockMovement {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  itemId    String   @map("item_id")
  type      String // in | out | adjustment | waste
  quantity  Decimal
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  branch Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

// ── 29. Notifications ────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  title     String
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
